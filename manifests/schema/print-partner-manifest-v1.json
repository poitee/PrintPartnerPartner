{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://print-partner.dev/schema/print-partner-manifest-v1.json",
  "title": "Print Partner manifest v1",
  "type": "object",
  "required": ["format", "version"],
  "properties": {
    "format": { "const": "print-partner-manifest" },
    "version": { "type": "integer", "minimum": 1 },
    "project": { "type": "string" },
    "option_groups": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["rule", "parts"],
        "properties": {
          "rule": { "enum": ["pick_one", "pick_any", "pick_n"] },
          "min": { "type": "integer" },
          "max": { "type": "integer" },
          "label": { "type": "string" },
          "parts": {
            "type": "array",
            "items": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "required": ["match"],
                  "properties": { "match": { "type": "string" } }
                }
              ]
            }
          },
          "variants": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id"],
              "properties": {
                "id": { "type": "string" },
                "label": { "type": "string" },
                "parts": {
                  "type": "array",
                  "items": {
                    "oneOf": [
                      { "type": "string" },
                      {
                        "type": "object",
                        "required": ["match"],
                        "properties": { "match": { "type": "string" } }
                      }
                    ]
                  }
                },
                "excludes": {
                  "type": "array",
                  "items": {
                    "oneOf": [
                      { "type": "string" },
                      {
                        "type": "object",
                        "required": ["match"],
                        "properties": { "match": { "type": "string" } }
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "parts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["match"],
        "properties": {
          "match": { "type": "string" },
          "requirement": { "enum": ["required", "optional", "recommended"] },
          "change": { "enum": ["base", "added", "replacement"] },
          "replaces": { "type": "string" },
          "default_included": { "type": "boolean" },
          "option_group": { "type": "string" },
          "slot": { "type": "string" },
          "replaces_slot": { "type": "string" }
        }
      }
    },
    "slots": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "default_group": { "type": "string" }
        }
      }
    },
    "choice_tree": {
      "type": "array",
      "items": { "type": "object" }
    },
    "addons": { "type": "array" }
  },
  "additionalProperties": true
}
